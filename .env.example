# ============================================
# App
# ============================================
# Public app name shown in browser UI.
NEXT_PUBLIC_APP_NAME=Your AI Companion
# Public base URL for canonical links and client-side redirects.
NEXT_PUBLIC_APP_URL=https://example.com
# Server-side runtime environment label.
NODE_ENV=development

# ============================================
# Supabase
# ============================================
# Public Supabase project URL (browser-safe).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Public Supabase anonymous key (browser-safe, RLS required).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Server-side Supabase service role key (never expose to browser).
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================
# OpenAI
# ============================================
# Server-side OpenAI API key.
OPENAI_API_KEY=your-openai-api-key

# ============================================
# Sentry Error Tracking
# ============================================
# Public Sentry DSN used by browser and runtime SDK initialization.
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Sentry auth token for source map upload during build (server-side only).
SENTRY_AUTH_TOKEN=your-sentry-auth-token
# Sentry organization slug for build-time source map upload.
SENTRY_ORG=your-sentry-org
# Sentry project slug for build-time source map upload.
SENTRY_PROJECT=your-sentry-project

# ============================================
# Vector Database / Qdrant (future)
# ============================================
# Server-side Qdrant endpoint URL.
QDRANT_URL=https://your-qdrant-cluster.qdrant.io
# Optional Qdrant API key if auth is enabled.
QDRANT_API_KEY=your-qdrant-api-key
# Optional default collection name for embeddings.
QDRANT_COLLECTION=ai_companion_embeddings

# ============================================
# ZeroFlow Platform Integration (optional, future)
# ============================================
# Optional ZeroFlow API base URL (env key prefix uses ZERO_FLOW_*).
ZERO_FLOW_API_URL=https://your-workspace.zeroflow.ai
# Optional server-side ZeroFlow API key.
ZERO_FLOW_API_KEY=your-zeroflow-api-key
