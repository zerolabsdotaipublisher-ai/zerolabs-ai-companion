# ============================================
# App
# ============================================
# Public app name shown in browser UI.
NEXT_PUBLIC_APP_NAME=Your AI Companion
# Public base URL for canonical links and client-side redirects.
NEXT_PUBLIC_APP_URL=https://your-app-domain.example.com
# Server-side runtime environment label.
NODE_ENV=development

# ============================================
# Supabase
# ============================================
# Public Supabase project URL (browser-safe).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Public Supabase anonymous key (browser-safe, RLS required).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Server-side Supabase service role key (never expose to browser).
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================
# OpenAI
# ============================================
# Server-side OpenAI API key.
OPENAI_API_KEY=your-openai-api-key
# Optional default OpenAI model ID used by server runtime.
OPENAI_MODEL=gpt-4o-mini

# ============================================
# Vector Database / Qdrant (future)
# ============================================
# Server-side Qdrant endpoint URL.
QDRANT_URL=https://your-qdrant-host.example.com
# Optional Qdrant API key if auth is enabled.
QDRANT_API_KEY=your-qdrant-api-key
# Optional default collection name for embeddings.
QDRANT_COLLECTION=ai_companion_embeddings

# ============================================
# Storage (future)
# ============================================
# Server-side storage provider identifier (e.g., wasabi, s3).
STORAGE_PROVIDER=wasabi
# Server-side storage region.
STORAGE_REGION=us-east-1
# Server-side storage bucket name.
STORAGE_BUCKET=your-storage-bucket
# Server-side storage endpoint URL.
STORAGE_ENDPOINT=https://s3.wasabisys.com
# Server-side storage access key ID.
STORAGE_ACCESS_KEY_ID=your-storage-access-key-id
# Server-side storage secret access key.
STORAGE_SECRET_ACCESS_KEY=your-storage-secret-access-key

# ============================================
# ZeroFlow Platform Integration (optional, future)
# ============================================
# Optional ZeroFlow API base URL.
ZEROFLOW_API_URL=https://api.zeroflow.example.com
# Optional ZeroFlow workspace or project identifier.
ZEROFLOW_PROJECT_ID=your-zeroflow-project-id
# Optional server-side ZeroFlow API key.
ZEROFLOW_API_KEY=your-zeroflow-api-key

# ============================================
# Runtime / Deployment
# ============================================
# Server-side log level for runtime diagnostics.
LOG_LEVEL=info
# Optional feature flag to enable verbose AI diagnostics.
AI_COMPANION_DEBUG=false
